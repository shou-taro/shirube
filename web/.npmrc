# Supply-chain hardening.

# Wait at least a day (1440 minutes) before installing a newly published version. This
# reduces exposure to a compromised release that is caught and yanked shortly after
# publication. It applies when resolving new versions; frozen-lockfile installs (CI)
# are unaffected.
minimum-release-age=1440

# Note: pnpm 10 does not run dependencies' build/lifecycle scripts unless they are
# explicitly allow-listed via `onlyBuiltDependencies`, which we deliberately leave unset.
